# ── LLM ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here   # Optional — used by memory_layers embedding

# ── Sandbox ───────────────────────────────────────────
E2B_API_KEY=your_key_here

# ── Web Research ──────────────────────────────────────
FIRECRAWL_API_KEY=your_key_here

# ── Documentation / Reporting ─────────────────────────
NOTION_API_KEY=your_key_here
NOTION_DATABASE_ID=your_database_id_here

# ── Memory ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here

# ── AWS (read-only IAM only — never give write access) ─
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_DEFAULT_REGION=us-east-1

# ── App ───────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://genesis:genesis_local@localhost:5432/genesis

# ── Bayesian Selector (research feature) ──────────────
# Set to false to disable and revert to vanilla greedy master
BAYESIAN_SELECTOR_ENABLED=true

# ── Obsidian Integration ───────────────────────────────
# Absolute path to your Obsidian vault folder on disk
# Leave blank to disable Obsidian integration
OBSIDIAN_VAULT_PATH=/Users/yourname/Documents/MyVault
# Subfolder inside vault where Genesis writes post-mortems
OBSIDIAN_GENESIS_FOLDER=Genesis/PostMortems
# Subfolder inside vault where your runbooks live (Genesis reads these)
OBSIDIAN_RUNBOOK_FOLDER=Runbooks

# ── Watchdog Continuous Monitoring ────────────────────
# Set to true to enable 24/7 proactive monitoring
WATCHDOG_ENABLED=false
# How often to run Tier 1 checks (seconds). Default 300 = every 5 minutes
WATCHDOG_INTERVAL_SECONDS=300
# Billing anomaly threshold — fraction above 7-day mean before alerting
# 0.40 = alert if yesterday's bill is 40% above the weekly average
WATCHDOG_BILLING_THRESHOLD=0.40
# Error spike threshold — multiplier above baseline before alerting
# 3.0 = alert if current hour errors are 3x the recent baseline
WATCHDOG_ERROR_THRESHOLD=3.0
